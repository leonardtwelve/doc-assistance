# Docmana API (issue #8)
# Voir docs/docmana-api.md pour la procédure complète.
DOCMANA_BASE_URL=
DOCMANA_API_KEY=
DOCMANA_WEBHOOK_SECRET=
# DOCMANA_MOCK=true bypass total : retourne une décision mock sans appel réseau.
# Si DOCMANA_BASE_URL est absent, le mock est activé automatiquement.
DOCMANA_MOCK=true
